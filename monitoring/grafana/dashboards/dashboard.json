{
  "dashboard": {
    "id": null,
    "uid": "heart-disease-api",
    "title": "Heart Disease API Monitoring",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Total Predictions",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(predictions_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 2,
        "title": "Predictions by Result",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "rate(predictions_total[1m])",
            "legendFormat": "{{result}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Prediction Latency (p95)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "id": 4,
        "title": "HTTP Requests Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
        "targets": [
          {
            "expr": "rate(http_requests_total[1m])",
            "legendFormat": "{{method}} {{endpoint}} {{status}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Prediction Latency Histogram",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 18, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(prediction_latency_seconds_sum[5m]) / rate(prediction_latency_seconds_count[5m])",
            "legendFormat": "avg latency"
          }
        ]
      }
    ],
    "refresh": "10s",
    "schemaVersion": 38,
    "version": 1
  }
}
